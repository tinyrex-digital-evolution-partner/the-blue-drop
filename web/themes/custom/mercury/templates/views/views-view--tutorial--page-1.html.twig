{#
/**
 * Template per tutorial — page_1 (pagina elenco tutorial).
 * Layout: hero small → breadcrumb → 33/66 (sidebar tutorial-menu | griglia 2 colonne).
 */
#}

{# ── Hero ─────────────────────────────────────────────────────────── #}
{{
  include(
    'mercury:hero',
    {
      variant: 'small',
      background_color: 'foreground',
      text_color: 'light',
      content_align: 'left',
      heading_level: 1,
      heading_text: 'Tutorial'
    },
    with_context: false
  )
}}

{# ── Breadcrumb ────────────────────────────────────────────────────── #}
{% if page_breadcrumb is not empty %}
  <div class="container mx-auto px-4 py-3">
    {{ page_breadcrumb }}
  </div>
{% endif %}

{# ── Layout 33/66 ──────────────────────────────────────────────────── #}
<div class="container mx-auto px-4 py-10 md:py-14">
  <div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-12">
    {# ── Sidebar — 33% ─────────────────────────────────────────────── #}
    <aside class="w-full shrink-0 lg:w-80 xl:w-96">
      <div class="flex flex-col gap-6 lg:sticky lg:top-8">
        {# Etichetta sezione #}
        <div>
          <p class="mb-1 px-1 text-xs font-bold tracking-widest text-foreground/40 uppercase">
            Argomenti
          </p>

          {# Decorazione colore — in futuro usa field_tutorial_topics_color dal termine attivo #}
          <div class="mb-4 h-1 w-12 rounded-full bg-accent"></div>

          {{ tutorial_menu }}
        </div>
      </div>
    </aside>

    {# ── Contenuto vista — 66% ─────────────────────────────────────── #}
    <div class="min-w-0 flex-1">
      {% if exposed %}
        <div class="view-filters mb-6">
          {{ exposed }}
        </div>
      {% endif %}

      {% if header %}
        <div class="view-header mb-6">
          {{ header }}
        </div>
      {% endif %}

      {% if rows %}
        <div class="view-content grid grid-cols-1 gap-6 sm:grid-cols-2">
          {{ rows }}
        </div>
      {% elseif empty %}
        <div class="view-empty py-12 text-center text-foreground/50">
          {{ empty }}
        </div>
      {% endif %}

      {% if pager %}
        <div class="mt-10">
          {{ pager }}
        </div>
      {% endif %}

      {% if footer %}
        <div class="view-footer mt-8">
          {{ footer }}
        </div>
      {% endif %}
    </div>
  </div>
</div>
