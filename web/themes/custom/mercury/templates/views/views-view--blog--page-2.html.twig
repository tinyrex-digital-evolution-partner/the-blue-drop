{#
/**
 * Template per blog — page_2 (pagina elenco articoli).
 * Layout: hero small → breadcrumb → 70/30 (contenuto | sidebar blog-menu).
 */
#}

{# ── Hero ─────────────────────────────────────────────────────────── #}
{{
  include(
    'mercury:hero',
    {
      variant: 'small',
      background_color: 'foreground',
      text_color: 'light',
      content_align: 'left',
      heading_level: 1,
      heading_text: 'Blog'
    },
    with_context: false
  )
}}

{# ── Breadcrumb ────────────────────────────────────────────────────── #}
{% if page_breadcrumb is not empty %}
  <div class="container mx-auto px-4 py-3">
    {{ page_breadcrumb }}
  </div>
{% endif %}

{# ── Layout 70/30 ──────────────────────────────────────────────────── #}
<div class="container mx-auto px-4 py-10 md:py-14">
  <div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-12">
    {# ── Contenuto vista — 70% ─────────────────────────────────────── #}
    <div class="min-w-0 flex-1">
      {% if exposed %}
        <div class="view-filters mb-6">
          {{ exposed }}
        </div>
      {% endif %}

      {% if header %}
        <div class="view-header mb-6">
          {{ header }}
        </div>
      {% endif %}

      {% if rows %}
        <div class="view-content flex flex-col gap-4">
          {{ rows }}
        </div>
      {% elseif empty %}
        <div class="view-empty py-12 text-center text-foreground/50">
          {{ empty }}
        </div>
      {% endif %}

      {% if pager %}
        <div class="mt-10">
          {{ pager }}
        </div>
      {% endif %}

      {% if footer %}
        <div class="view-footer mt-8">
          {{ footer }}
        </div>
      {% endif %}
    </div>

    {# ── Sidebar — 30% ─────────────────────────────────────────────── #}
    <aside class="w-full shrink-0 lg:w-72 xl:w-80">
      <div class="flex flex-col gap-6 lg:sticky lg:top-8">
        <div>
          <p class="mb-3 px-4 text-xs font-bold tracking-widest text-foreground/40 uppercase">
            Categorie
          </p>
          {{ blog_menu }}
        </div>
      </div>
    </aside>
  </div>
</div>
