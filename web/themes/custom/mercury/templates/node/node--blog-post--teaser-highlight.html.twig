{% set has_image = content.field_blog_post_image|render|striptags|trim is not empty %}
{% set has_caption = node.field_blog_post_caption.value is not empty %}
{% set has_preview = node.field_blog_post_preview.value is not empty %}

<article
  class="group flex flex-col overflow-hidden rounded-xl bg-card shadow-md transition-all duration-300 hover:-translate-y-px hover:shadow-lg sm:flex-row"
>
  {# ── Immagine — 33% ─────────────────────────────────────────────── #}
  <a href="{{ url }}" class="relative aspect-video w-full shrink-0 overflow-hidden sm:aspect-auto sm:w-1/3" tabindex="-1" aria-hidden="true">
    {% if has_image %}
      <div class="image-cover-container image-cover-container--slow">
        {{ content.field_blog_post_image }}
      </div>
    {% else %}
      <div class="absolute inset-0 bg-gradient-to-br from-primary/80 via-primary to-accent/70"></div>
      <div class="absolute -right-6 -bottom-6 h-28 w-28 rounded-full bg-white/5"></div>
      <div class="absolute -top-3 -left-3 h-14 w-14 rounded-full bg-white/5"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <svg
          viewBox="0 0 80 80"
          class="h-14 w-14 text-white/25"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="14" y="10" width="52" height="60" rx="6" stroke-width="2.5" />
          <line x1="26" y1="30" x2="54" y2="30" stroke-width="2.5" />
          <line x1="26" y1="42" x2="54" y2="42" stroke-width="2.5" />
          <line x1="26" y1="54" x2="42" y2="54" stroke-width="2.5" />
        </svg>
      </div>
    {% endif %}
    <div class="absolute top-3 left-3 z-10">
      <span class="rounded-full border border-white/30 bg-white/20 px-2.5 py-1 text-xs font-semibold text-white backdrop-blur-sm">Blog</span>
    </div>
  </a>

  {# ── Contenuto — 66% ────────────────────────────────────────────── #}
  <div class="flex flex-1 flex-col gap-3 p-5">
    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {% if has_caption %}
      <p class="-mt-1 text-sm font-semibold text-primary">
        {{ node.field_blog_post_caption.value }}
      </p>
    {% endif %}

    {% if has_preview %}
      <p class="line-clamp-2 text-sm leading-relaxed text-foreground/70">
        {{ node.field_blog_post_preview.value }}
      </p>
    {% endif %}

    <div class="mt-auto pt-3">
      <a
        href="{{ url }}"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-3"
        aria-label="Leggi {{ label }}"
      >
        Leggi<svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
