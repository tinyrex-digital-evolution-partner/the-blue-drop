{% set has_caption = node.field_blog_post_caption.value is not empty %}
{% set has_preview = node.field_blog_post_preview.value is not empty %}

<article class="group flex overflow-hidden border-l-4 border-l-primary bg-background shadow-sm transition-all duration-300 hover:shadow-md">
  <div class="flex flex-1 flex-col gap-1 px-5 py-3">
    <span class="text-xs font-bold tracking-widest text-primary uppercase">Blog</span>

    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {% if has_caption %}
      <p class="text-sm font-semibold text-accent-foreground">
        {{ node.field_blog_post_caption.value }}
      </p>
    {% endif %}

    {% if has_preview %}
      <p class="line-clamp-1 text-sm leading-relaxed text-foreground/60">
        {{ node.field_blog_post_preview.value }}
      </p>
    {% endif %}

    <div class="flex justify-end pt-2">
      {{
        include(
          'mercury:button',
          {
            variant: 'primary-inverted',
            size: 'small',
            label: 'Leggi',
            href: url,
            icon: 'arrow-right'
          },
          with_context: false
        )
      }}
    </div>
  </div>
</article>
