{% set has_preview = node.field_tutorial_preview.value is not empty %}
{% set has_level = node.field_tutorial_level.entity is not empty %}

<article
  class="group flex flex-col overflow-hidden rounded-xl bg-card shadow-md transition-all duration-300 hover:-translate-y-px hover:shadow-lg sm:flex-row"
>
  {# ── Pannello icona — 33% ───────────────────────────────────────── #}
  <a
    href="{{ url }}"
    class="relative flex w-full shrink-0 items-center justify-center overflow-hidden bg-muted/50 sm:w-1/3"
    tabindex="-1"
    aria-hidden="true"
  >
    <div class="absolute -right-8 -bottom-8 h-32 w-32 rounded-full bg-primary/5"></div>
    <div class="flex flex-col items-center gap-3 py-8 sm:py-0">
      <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
        <svg
          viewBox="0 0 24 24"
          class="h-7 w-7 text-primary"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="16 18 22 12 16 6" />
          <polyline points="8 6 2 12 8 18" />
        </svg>
      </div>
      {% if has_level %}
        <span class="inline-flex items-center gap-1 text-xs font-semibold text-primary">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
          {{ node.field_tutorial_level.entity.label }}
        </span>
      {% else %}
        <span class="text-xs font-bold tracking-widest text-foreground/40 uppercase">Tutorial</span>
      {% endif %}
    </div>
  </a>

  {# ── Contenuto — 66% ────────────────────────────────────────────── #}
  <div class="flex flex-1 flex-col gap-3 p-5">
    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {% if has_preview %}
      <p class="line-clamp-3 text-sm leading-relaxed text-foreground/70">
        {{ node.field_tutorial_preview.value }}
      </p>
    {% endif %}

    <div class="mt-auto pt-3">
      <a
        href="{{ url }}"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-3"
        aria-label="Inizia {{ label }}"
      >
        Inizia<svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
