{% set has_preview = node.field_tutorial_preview.value is not empty %}
{% set has_level = node.field_tutorial_level.entity is not empty %}

<article class="group flex overflow-hidden border-l-4 border-l-foreground bg-card shadow-sm transition-all duration-300 hover:shadow-md">
  <div class="flex flex-1 flex-col gap-1.5 px-5 py-3">
    <div class="flex items-center gap-3">
      <span class="text-xs font-bold tracking-widest text-foreground/50 uppercase">Tutorial</span>
      {% if has_level %}
        <span class="border-l border-foreground/15 pl-3 text-xs font-semibold text-foreground/70">{{ node.field_tutorial_level.entity.label }}</span>
      {% endif %}
    </div>

    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {% if has_preview %}
      <p class="line-clamp-1 text-sm leading-relaxed text-foreground/60">
        {{ node.field_tutorial_preview.value }}
      </p>
    {% endif %}

    <div class="flex justify-end pt-2">
      {{
        include(
          'mercury:button',
          {
            variant: 'primary-inverted',
            size: 'small',
            label: 'Inizia',
            href: url,
            icon: 'arrow-right'
          },
          with_context: false
        )
      }}
    </div>
  </div>
</article>
