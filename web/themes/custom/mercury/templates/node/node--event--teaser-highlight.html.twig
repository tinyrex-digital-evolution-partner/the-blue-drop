{% set has_image = content.field_event_image|render|striptags|trim is not empty %}
{% set has_date = node.field_event_date.value is not empty %}
{% set has_date_end = node.field_event_date_end.value is not empty %}
{% set has_location = node.field_event_localtion.value is not empty %}

<article
  class="group flex flex-col overflow-hidden rounded-xl bg-card shadow-md transition-all duration-300 hover:-translate-y-px hover:shadow-lg sm:flex-row"
>
  {# ── Immagine — 33% ─────────────────────────────────────────────── #}
  <a href="{{ url }}" class="relative aspect-video w-full shrink-0 overflow-hidden sm:aspect-auto sm:w-1/3" tabindex="-1" aria-hidden="true">
    {% if has_image %}
      <div class="image-cover-container image-cover-container--slow">
        {{ content.field_event_image }}
      </div>
    {% else %}
      <div class="absolute inset-0 bg-gradient-to-br from-secondary-foreground via-foreground to-secondary-foreground"></div>
      <div class="absolute -right-8 -bottom-8 h-32 w-32 rounded-full bg-white/5"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <svg
          viewBox="0 0 80 80"
          class="h-14 w-14 text-white/25"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="12" y="14" width="56" height="52" rx="6" stroke-width="2.5" />
          <line x1="24" y1="8" x2="24" y2="20" stroke-width="2.5" />
          <line x1="56" y1="8" x2="56" y2="20" stroke-width="2.5" />
          <line x1="12" y1="28" x2="68" y2="28" stroke-width="2.5" />
        </svg>
      </div>
    {% endif %}
    {% if has_date %}
      <div class="absolute top-3 right-3 z-10 flex flex-col items-center rounded-lg bg-card/90 px-3 py-2 text-center shadow-sm backdrop-blur-sm">
        <span class="text-xl leading-none font-bold text-foreground">{{ node.field_event_date.value|date('d') }}</span>
        <span class="text-xs font-semibold tracking-wide text-primary uppercase">{{ node.field_event_date.value|date('M') }}</span>
      </div>
    {% endif %}
  </a>

  {# ── Contenuto — 66% ────────────────────────────────────────────── #}
  <div class="flex flex-1 flex-col gap-3 p-5">
    {% if has_date %}
      <div class="flex items-center gap-2 text-xs font-medium text-foreground/50">
        <svg
          class="h-3.5 w-3.5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        <time datetime="{{ node.field_event_date.value|date('Y-m-d') }}">{{ node.field_event_date.value|date('d M Y') }}</time>
        {% if has_date_end %}
          <span class="text-foreground/30">—</span>
          <time datetime="{{ node.field_event_date_end.value|date('Y-m-d') }}">{{ node.field_event_date_end.value|date('d M Y') }}</time>
        {% endif %}
      </div>
    {% endif %}

    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {% if has_location %}
      <div class="mt-auto flex items-center gap-2 pt-3 text-sm text-foreground/60">
        <svg
          class="h-4 w-4 shrink-0 text-primary/60"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        <span>{{ node.field_event_localtion.value }}</span>
      </div>
    {% endif %}
  </div>
</article>
