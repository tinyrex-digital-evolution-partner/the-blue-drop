{% set has_date = node.field_event_date.value is not empty %}
{% set has_date_end = node.field_event_date_end.value is not empty %}
{% set has_location = node.field_event_localtion.value is not empty %}

<article class="group flex overflow-hidden border-l-4 border-l-accent bg-card shadow-sm transition-all duration-300 hover:shadow-md">
  {% if has_date %}
    <div class="flex w-28 shrink-0 flex-col items-center justify-center border-r border-foreground/5 bg-accent/5 px-2 py-3">
      <span class="text-center text-[11px] leading-tight font-semibold text-accent-foreground">{{ node.field_event_date.value|date('d/m/Y') }}</span>
      <span class="text-center text-[11px] leading-tight font-semibold text-accent-foreground/80">- {{ node.field_event_date.value|date('H:i') }}</span>
    </div>
  {% endif %}

  <div class="flex flex-1 flex-col gap-1.5 px-5 py-3">
    {% if has_date %}
      <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-foreground/50">
        <time datetime="{{ node.field_event_date.value|date('Y-m-d H:i') }}">{{ node.field_event_date.value|date('d/m/Y - H:i') }}</time>
        {% if has_date_end %}
          <span class="text-foreground/30">—</span>
          <time datetime="{{ node.field_event_date_end.value|date('Y-m-d H:i') }}">{{ node.field_event_date_end.value|date('d/m/Y - H:i') }}</time>
        {% endif %}
      </div>
    {% endif %}

    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {% if has_location %}
      <div class="flex items-center gap-2 pt-1 text-xs text-foreground/60">
        <svg
          class="h-3.5 w-3.5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        <span>{{ node.field_event_localtion.value }}</span>
      </div>
    {% endif %}
  </div>
</article>
