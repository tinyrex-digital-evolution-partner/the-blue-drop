{% set has_image = content.field_blog_post_image|render|striptags|trim is not empty %}
{% set has_caption = node.field_blog_post_caption.value is not empty %}
{% set has_preview = node.field_blog_post_preview.value is not empty %}
{% set has_tags = node.field_blog_post_tags is not empty %}
{% set has_topics = node.field_blog_post_topics is not empty %}
{% set author = node.owner %}
{% set has_author = author is not empty %}

<article class="group flex h-full flex-col overflow-hidden bg-card transition-all duration-300 hover:-translate-y-1">
  {# ── Header visuale ────────────────────────────────────────────── #}
  <a href="{{ url }}" class="relative block aspect-[16/9] overflow-hidden" tabindex="-1" aria-hidden="true">
    {% if has_image %}
      {# Immagine del campo #}
      <div class="image-cover-container">
        {{ content.field_blog_post_image }}
      </div>
    {% else %}
      {# Gradiente di default #}
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-accent"></div>

      {# Overlay colorato al 70% #}
      <div class="absolute inset-0 bg-primary/70 transition-opacity duration-300 group-hover:bg-primary/60"></div>

      {# Decorazione geometrica di sfondo #}
      <div class="absolute -right-8 -bottom-8 h-48 w-48 rounded-full bg-white/5"></div>
      <div class="absolute -top-4 -left-4 h-24 w-24 rounded-full bg-white/5"></div>

      {# Icona decorativa centrata (header_card statica) #}
      <div class="absolute inset-0 flex items-center justify-center">
        <svg
          viewBox="0 0 80 80"
          class="h-24 w-24 text-white/25"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="14" y="10" width="52" height="60" rx="6" stroke-width="2.5" />
          <line x1="26" y1="30" x2="54" y2="30" stroke-width="2.5" />
          <line x1="26" y1="42" x2="54" y2="42" stroke-width="2.5" />
          <line x1="26" y1="54" x2="42" y2="54" stroke-width="2.5" />
          <circle cx="60" cy="58" r="10" fill="currentColor" stroke="none" class="text-white/20" />
          <line x1="57" y1="58" x2="63" y2="58" stroke-width="2" class="text-white/60" />
          <line x1="60" y1="55" x2="60" y2="61" stroke-width="2" class="text-white/60" />
        </svg>
      </div>
    {% endif %}

    {# Topics in overlay — top left #}
    {% if has_topics %}
      <div class="absolute top-4 left-4 z-10 flex flex-wrap gap-1.5">
        {% for item in node.field_blog_post_topics %}
          {% if item.entity %}
            <span class="rounded-full border border-white/30 bg-white/20 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
              {{ item.entity.label }}
            </span>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="absolute top-4 left-4 z-10">
        <span class="rounded-full border border-white/30 bg-white/20 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">Articolo</span>
      </div>
    {% endif %}

    {# Data in overlay — bottom left #}
    <div class="absolute bottom-4 left-4 z-10">
      <time class="text-xs font-medium text-white/80" datetime="{{ node.createdtime|date('Y-m-d') }}">{{ node.createdtime|date('d M Y') }}</time>
    </div>

    {# Lettura stimata — bottom right (statico) #}
    <div class="absolute right-4 bottom-4 z-10 flex items-center gap-1 text-xs text-white/70">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>5 min
    </div>
  </a>

  {# ── Card body ──────────────────────────────────────────────────── #}
  <div class="flex flex-1 flex-col gap-4 p-6">
    {# Tags #}
    {% if has_tags %}
      <div class="flex flex-wrap gap-2">
        {% for item in node.field_blog_post_tags %}
          {% if item.entity %}
            <span class="rounded-full bg-accent px-2.5 py-1 text-xs font-medium text-accent-foreground">{{ item.entity.label }}</span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {# Title #}
    <h3 class="text-xl leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {# Caption #}
    {% if has_caption %}
      <p class="-mt-2 text-sm font-semibold text-primary">
        {{ node.field_blog_post_caption.value }}
      </p>
    {% endif %}

    {# Preview #}
    {% if has_preview %}
      <p class="line-clamp-2 text-sm leading-relaxed text-foreground/70">
        {{ node.field_blog_post_preview.value }}
      </p>
    {% else %}
      <p class="line-clamp-2 text-sm leading-relaxed text-foreground/50 italic">
        Leggi l'articolo completo per scoprire tutti i dettagli.
      </p>
    {% endif %}

    {# ── Author row ─────────────────────────────────────────────── #}
    {% if has_author %}
      {% set author_picture = author.user_picture.entity %}
      <div class="mt-auto flex items-center gap-3 border-t border-foreground/8 pt-4">
        {% if author_profile_title is defined and author_profile_title is not empty %}
          <a
            href="{{
            path(
              'entity.user.canonical',
              {
                user: author.id
              }
            )
            }}"
            title="{{ author_profile_title }}"
            class="shrink-0"
            aria-label="{{ author.displayname }}"
          >
            <span
              class="flex h-9 w-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground uppercase ring-2 ring-primary/20 select-none"
            >
              {{ author.displayname|slice(0, 1) }}
            </span>
          </a>
        {% else %}
          <a
            href="{{
            path(
              'entity.user.canonical',
              {
                user: author.id
              }
            )
            }}"
            class="shrink-0"
            aria-label="{{ author.displayname }}"
          >
            <span
              class="flex h-9 w-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground uppercase ring-2 ring-primary/20 select-none"
            >
              {{ author.displayname|slice(0, 1) }}
            </span>
          </a>
        {% endif %}

        <div class="flex min-w-0 flex-col">
          {% if author_profile_title is defined and author_profile_title is not empty %}
            <a
              href="{{
              path(
                'entity.user.canonical',
                {
                  user: author.id
                }
              )
              }}"
              title="{{ author_profile_title }}"
              class="truncate text-sm leading-tight font-semibold transition-colors duration-200 hover:text-primary"
            >
              {{ author.displayname }}
            </a>
          {% else %}
            <a
              href="{{
              path(
                'entity.user.canonical',
                {
                  user: author.id
                }
              )
              }}"
              class="truncate text-sm leading-tight font-semibold transition-colors duration-200 hover:text-primary"
            >
              {{ author.displayname }}
            </a>
          {% endif %}
          <span class="text-xs text-foreground/50">Autore</span>
        </div>

        {{
          include(
            'mercury:button',
            {
              variant: 'primary-inverted',
              size: 'small',
              label: 'Leggi',
              href: url,
              icon: 'arrow-right',
              btn_classes: ['ml-auto', 'shrink-0']
            },
            with_context: false
          )
        }}
      </div>
    {% else %}
      <div class="mt-auto flex justify-end border-t border-foreground/8 pt-4">
        {{
          include(
            'mercury:button',
            {
              variant: 'primary-inverted',
              size: 'small',
              label: 'Leggi',
              href: url,
              icon: 'arrow-right'
            },
            with_context: false
          )
        }}
      </div>
    {% endif %}
  </div>
</article>
