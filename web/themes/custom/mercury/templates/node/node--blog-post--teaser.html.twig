{%
  set has_image = node.field_blog_post_image.entity is not empty
%}
{% set has_caption = node.field_blog_post_caption.value is not empty %}
{% set has_preview = node.field_blog_post_preview.value is not empty %}
{% set has_tags = node.field_blog_post_tags is not empty %}
{% set has_topics = node.field_blog_post_topics is not empty %}
{% set author = node.owner %}
{% set has_author = author is not empty %}

<article class="group flex flex-col overflow-hidden bg-card transition-all duration-300 hover:-translate-y-1 h-full">

  {# ── Header visuale ────────────────────────────────────────────── #}
  <a href="{{ url }}" class="block relative overflow-hidden aspect-[16/9]" tabindex="-1" aria-hidden="true">

    {# Immagine di sfondo #}
    {% if has_image %}
      <div class="absolute inset-0 [&_img]:w-full [&_img]:h-full [&_img]:object-cover [&_img]:transition-transform [&_img]:duration-700 group-hover:[&_img]:scale-110">
        {{ content.field_blog_post_image }}
      </div>
    {% else %}
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-accent"></div>
    {% endif %}

    {# Overlay colorato al 70% #}
    <div class="absolute inset-0 bg-primary/70 transition-opacity duration-300 group-hover:bg-primary/60"></div>

    {# Decorazione geometrica di sfondo #}
    <div class="absolute -bottom-8 -right-8 w-48 h-48 rounded-full bg-white/5"></div>
    <div class="absolute -top-4 -left-4 w-24 h-24 rounded-full bg-white/5"></div>

    {# Icona decorativa centrata (header_card statica) #}
    <div class="absolute inset-0 flex items-center justify-center">
      <svg viewBox="0 0 80 80" class="w-24 h-24 text-white/25" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="14" y="10" width="52" height="60" rx="6" stroke-width="2.5"/>
        <line x1="26" y1="30" x2="54" y2="30" stroke-width="2.5"/>
        <line x1="26" y1="42" x2="54" y2="42" stroke-width="2.5"/>
        <line x1="26" y1="54" x2="42" y2="54" stroke-width="2.5"/>
        <circle cx="60" cy="58" r="10" fill="currentColor" stroke="none" class="text-white/20"/>
        <line x1="57" y1="58" x2="63" y2="58" stroke-width="2" class="text-white/60"/>
        <line x1="60" y1="55" x2="60" y2="61" stroke-width="2" class="text-white/60"/>
      </svg>
    </div>

    {# Topics in overlay — top left #}
    {% if has_topics %}
      <div class="absolute top-4 left-4 flex flex-wrap gap-1.5 z-10">
        {% for item in node.field_blog_post_topics %}
          {% if item.entity %}
            <span class="text-xs font-semibold px-3 py-1 rounded-full bg-white/20 text-white backdrop-blur-sm border border-white/30">
              {{ item.entity.label }}
            </span>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="absolute top-4 left-4 z-10">
        <span class="text-xs font-semibold px-3 py-1 rounded-full bg-white/20 text-white backdrop-blur-sm border border-white/30">
          Articolo
        </span>
      </div>
    {% endif %}

    {# Data in overlay — bottom left #}
    <div class="absolute bottom-4 left-4 z-10">
      <time class="text-xs font-medium text-white/80" datetime="{{ node.createdtime|date('Y-m-d') }}">
        {{ node.createdtime|date('d M Y') }}
      </time>
    </div>

    {# Lettura stimata — bottom right (statico) #}
    <div class="absolute bottom-4 right-4 z-10 flex items-center gap-1 text-white/70 text-xs">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      5 min
    </div>

  </a>

  {# ── Card body ──────────────────────────────────────────────────── #}
  <div class="flex flex-col flex-1 gap-4 p-6">

    {# Tags #}
    {% if has_tags %}
      <div class="flex flex-wrap gap-2">
        {% for item in node.field_blog_post_tags %}
          {% if item.entity %}
            <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-accent text-accent-foreground">
              {{ item.entity.label }}
            </span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {# Title #}
    <h3 class="text-xl font-bold leading-snug tracking-tight">
      <a href="{{ url }}" class="hover:text-primary transition-colors duration-200">
        {{ label }}
      </a>
    </h3>

    {# Caption #}
    {% if has_caption %}
      <p class="text-sm font-semibold text-primary -mt-2">
        {{ node.field_blog_post_caption.value }}
      </p>
    {% endif %}

    {# Preview #}
    {% if has_preview %}
      <p class="text-sm leading-relaxed line-clamp-2 text-foreground/70">
        {{ node.field_blog_post_preview.value }}
      </p>
    {% else %}
      <p class="text-sm leading-relaxed line-clamp-2 text-foreground/50 italic">
        Leggi l'articolo completo per scoprire tutti i dettagli.
      </p>
    {% endif %}

    {# ── Author row ─────────────────────────────────────────────── #}
    {% if has_author %}
      {% set author_picture = author.user_picture.entity %}
      <div class="flex items-center gap-3 pt-4 mt-auto border-t border-foreground/8">

        <a href="{{ path('entity.user.canonical', {'user': author.id}) }}" class="shrink-0" aria-label="{{ author.displayname }}">
          <span class="w-9 h-9 rounded-full bg-primary text-primary-foreground flex items-center justify-center text-sm font-bold uppercase select-none ring-2 ring-primary/20">
            {{ author.displayname|slice(0, 1) }}
          </span>
        </a>

        <div class="flex flex-col min-w-0">
          <a href="{{ path('entity.user.canonical', {'user': author.id}) }}" class="text-sm font-semibold hover:text-primary transition-colors duration-200 truncate leading-tight">
            {{ author.displayname }}
          </a>
          <span class="text-xs text-foreground/50">Autore</span>
        </div>

        <a href="{{ url }}" class="ml-auto shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-primary/10 text-primary hover:bg-primary hover:text-primary-foreground transition-all duration-200" aria-label="Leggi articolo">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

      </div>
    {% else %}
      <div class="pt-4 mt-auto border-t border-foreground/8">
        <a href="{{ url }}" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:gap-3 transition-all duration-200">
          Leggi articolo
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    {% endif %}

  </div>
</article>
