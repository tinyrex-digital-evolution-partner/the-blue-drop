{% set has_preview = node.field_content_page_preview.value is not empty %}

<article class="group overflow-hidden border-t-2 border-t-secondary-foreground bg-card shadow-sm transition-all duration-300 hover:shadow-md">
  <div class="flex flex-col gap-1.5 px-5 py-3">
    <span class="text-xs font-bold tracking-widest text-secondary-foreground/60 uppercase">Pagina</span>

    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {% if has_preview %}
      <p class="line-clamp-1 text-sm leading-relaxed text-foreground/60">
        {{ node.field_content_page_preview.value }}
      </p>
    {% endif %}

    <div class="flex justify-end pt-2">
      {{
        include(
          'mercury:button',
          {
            variant: 'primary-inverted',
            size: 'small',
            label: 'Scopri',
            href: url,
            icon: 'arrow-right'
          },
          with_context: false
        )
      }}
    </div>
  </div>
</article>
