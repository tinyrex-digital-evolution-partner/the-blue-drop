{% set has_preview = node.field_content_page_preview.value is not empty %}

<article
  class="group flex flex-col overflow-hidden rounded-xl bg-card shadow-md transition-all duration-300 hover:-translate-y-px hover:shadow-lg sm:flex-row"
>
  {# ── Pannello decorativo — 33% ──────────────────────────────────── #}
  <a
    href="{{ url }}"
    class="relative flex w-full shrink-0 items-center justify-center overflow-hidden bg-gradient-to-br from-accent/20 via-primary/10 to-secondary/20 sm:w-1/3"
    tabindex="-1"
    aria-hidden="true"
  >
    <div class="absolute -right-6 -bottom-6 h-28 w-28 rounded-full bg-primary/5"></div>
    <div class="absolute -top-3 -left-3 h-14 w-14 rounded-full bg-accent/5"></div>
    <div class="flex flex-col items-center gap-2 py-8 sm:py-0">
      <svg
        viewBox="0 0 24 24"
        class="h-10 w-10 text-primary/30"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
      </svg>
      <span class="text-xs font-bold tracking-widest text-primary/40 uppercase">Pagina</span>
    </div>
  </a>

  {# ── Contenuto — 66% ────────────────────────────────────────────── #}
  <div class="flex flex-1 flex-col gap-4 p-5">
    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {% if has_preview %}
      <p class="line-clamp-3 text-sm leading-relaxed text-foreground/70">
        {{ node.field_content_page_preview.value }}
      </p>
    {% endif %}

    <div class="mt-auto pt-3">
      <a
        href="{{ url }}"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-3"
        aria-label="Scopri {{ label }}"
      >
        Scopri<svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
