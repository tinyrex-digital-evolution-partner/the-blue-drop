{% set has_preview = node.field_tutorial_preview.value is not empty %}
{% set has_level = node.field_tutorial_level.entity is not empty %}
{% set has_topics = node.field_tutorial_topics is not empty %}

{# Colore dal primo topic (sempre presente per via del default) #}
{% set first_topic = node.field_tutorial_topics[0].entity ?? null %}
{% set topic_color = first_topic and first_topic.field_tutorial_topics_color.value is not empty ? first_topic.field_tutorial_topics_color.value : null
%}

<article class="group flex h-full flex-col overflow-hidden bg-card transition-all duration-300 hover:-translate-y-1">
  {# ── Header visuale ────────────────────────────────────────────── #}
  <a href="{{ url }}" class="relative block aspect-[16/9] overflow-hidden" tabindex="-1" aria-hidden="true">
    {# Sfondo: colore del topic o gradiente di fallback #}
    {% if topic_color %}
      <div class="absolute inset-0" style="background-color: {{ topic_color }};"></div>
    {% else %}
      <div class="absolute inset-0 bg-gradient-to-br from-secondary-foreground via-secondary-foreground to-foreground"></div>
    {% endif %}

    {# Overlay scuro per leggibilità #}
    <div class="absolute inset-0 bg-black/30 transition-opacity duration-300 group-hover:bg-black/20"></div>

    {# Decorazione geometrica #}
    <div class="absolute -right-10 -bottom-10 h-56 w-56 rounded-full bg-white/5"></div>
    <div class="absolute top-0 left-0 h-32 w-32 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/5"></div>

    {# Icona decorativa centrata — codice/tutorial (statica) #}
    <div class="absolute inset-0 flex items-center justify-center">
      <svg
        viewBox="0 0 80 80"
        class="h-24 w-24 text-white/25"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="26,24 10,40 26,56" stroke-width="2.5" />
        <polyline points="54,24 70,40 54,56" stroke-width="2.5" />
        <line x1="46" y1="18" x2="34" y2="62" stroke-width="2.5" />
      </svg>
    </div>

    {# Level badge — top left #}
    <div class="absolute top-4 left-4 z-10">
      {% if has_level %}
        <span
          class="inline-flex items-center gap-1.5 rounded-full border border-white/30 bg-white/20 px-3 py-1.5 text-xs font-bold tracking-wider text-white uppercase backdrop-blur-sm"
        >
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
          {{ has_level ? node.field_tutorial_level.entity.label : 'Tutorial' }}
        </span>
      {% else %}
        <span
          class="inline-flex items-center gap-1.5 rounded-full border border-white/30 bg-white/20 px-3 py-1.5 text-xs font-bold tracking-wider text-white uppercase backdrop-blur-sm"
        >
          Tutorial
        </span>
      {% endif %}
    </div>
  </a>

  {# ── Card body ──────────────────────────────────────────────────── #}
  <div class="flex flex-1 flex-col gap-4 p-6">
    {# Title #}
    <h3 class="text-xl font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 group-hover:text-primary">{{ label }}</a>
    </h3>

    {# Preview #}
    {% if has_preview %}
      <p class="line-clamp-3 text-sm leading-relaxed text-foreground/70">
        {{ node.field_tutorial_preview.value }}
      </p>
    {% else %}
      <p class="line-clamp-3 text-sm leading-relaxed text-foreground/50 italic">
        Una guida dettagliata passo dopo passo per apprendere questa tecnologia.
      </p>
    {% endif %}

    {# Footer card #}
    <div class="mt-auto flex items-center justify-between border-t border-foreground/8 pt-4">
      <div class="flex items-center gap-2">
        {% if first_topic %}
          <span class="rounded-full bg-accent px-2.5 py-1 text-xs font-medium text-accent-foreground">{{ first_topic.label }}</span>
        {% endif %}
      </div>
      {{
        include(
          'mercury:button',
          {
            variant: 'primary-inverted',
            size: 'small',
            label: 'Inizia',
            href: url,
            icon: 'arrow-right'
          },
          with_context: false
        )
      }}
    </div>
  </div>
</article>
