{% set has_preview = node.field_tutorial_preview.value is not empty %}
{% set has_level = node.field_tutorial_level.entity is not empty %}
{% set has_topics = node.field_tutorial_topics is not empty %}

{# Colore dal primo topic (sempre presente per via del default) #}
{% set first_topic = node.field_tutorial_topics[0].entity ?? null %}
{% set topic_color = (first_topic and first_topic.field_tutorial_topics_color.value is not empty)
  ? first_topic.field_tutorial_topics_color.value
  : null %}

<article class="group flex flex-col overflow-hidden bg-card transition-all duration-300 hover:-translate-y-1 h-full">

  {# ── Header visuale ────────────────────────────────────────────── #}
  <a href="{{ url }}" class="block relative overflow-hidden aspect-[16/9]" tabindex="-1" aria-hidden="true">

    {# Sfondo: colore del topic o gradiente di fallback #}
    {% if topic_color %}
      <div class="absolute inset-0" style="background-color: {{ topic_color }};"></div>
    {% else %}
      <div class="absolute inset-0 bg-gradient-to-br from-secondary-foreground via-secondary-foreground to-foreground"></div>
    {% endif %}

    {# Overlay scuro per leggibilità #}
    <div class="absolute inset-0 bg-black/30 transition-opacity duration-300 group-hover:bg-black/20"></div>

    {# Decorazione geometrica #}
    <div class="absolute -bottom-10 -right-10 w-56 h-56 rounded-full bg-white/5"></div>
    <div class="absolute top-0 left-0 w-32 h-32 rounded-full bg-white/5 -translate-x-1/2 -translate-y-1/2"></div>

    {# Icona decorativa centrata — codice/tutorial (statica) #}
    <div class="absolute inset-0 flex items-center justify-center">
      <svg viewBox="0 0 80 80" class="w-24 h-24 text-white/25" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="26,24 10,40 26,56" stroke-width="2.5"/>
        <polyline points="54,24 70,40 54,56" stroke-width="2.5"/>
        <line x1="46" y1="18" x2="34" y2="62" stroke-width="2.5"/>
      </svg>
    </div>

    {# Level badge — top left #}
    <div class="absolute top-4 left-4 z-10">
      {% if has_level %}
        <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1.5 rounded-full bg-white/20 text-white backdrop-blur-sm border border-white/30 uppercase tracking-wider">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          {{ has_level ? node.field_tutorial_level.entity.label : 'Tutorial' }}
        </span>
      {% else %}
        <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1.5 rounded-full bg-white/20 text-white backdrop-blur-sm border border-white/30 uppercase tracking-wider">
          Tutorial
        </span>
      {% endif %}
    </div>

    {# Durata stimata — bottom right (statica) #}
    <div class="absolute bottom-4 right-4 z-10 flex items-center gap-1 text-white/70 text-xs">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
      </svg>
      Guida pratica
    </div>

  </a>

  {# ── Card body ──────────────────────────────────────────────────── #}
  <div class="flex flex-col flex-1 gap-4 p-6">

    {# Title #}
    <h3 class="text-xl font-bold leading-snug tracking-tight">
      <a href="{{ url }}" class="group-hover:text-primary transition-colors duration-200">
        {{ label }}
      </a>
    </h3>

    {# Preview #}
    {% if has_preview %}
      <p class="text-sm leading-relaxed line-clamp-3 text-foreground/70">
        {{ node.field_tutorial_preview.value }}
      </p>
    {% else %}
      <p class="text-sm leading-relaxed line-clamp-3 text-foreground/50 italic">
        Una guida dettagliata passo dopo passo per apprendere questa tecnologia.
      </p>
    {% endif %}

    {# Topics #}
    {% if has_topics %}
      <div class="flex flex-wrap gap-2 mt-auto">
        {% for item in node.field_tutorial_topics %}
          {% if item.entity %}
            <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-accent text-accent-foreground">
              {{ item.entity.label }}
            </span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {# Footer card #}
    <div class="flex items-center justify-between pt-4 mt-auto border-t border-foreground/8">
      <div class="flex items-center gap-2 text-xs text-foreground/50">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <time datetime="{{ node.createdtime|date('Y-m-d') }}">{{ node.createdtime|date('d M Y') }}</time>
      </div>

      <a href="{{ url }}" class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:gap-3 transition-all duration-200" aria-label="Inizia {{ label }}">
        Inizia
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</article>
