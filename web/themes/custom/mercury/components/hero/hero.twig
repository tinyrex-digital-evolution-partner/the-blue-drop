{% set hero_variant = variant|default('big') %}
{% set hero_text_color = text_color|default('light') %}
{% set hero_heading_level = heading_level|default(1) %}
{% set hero_align = content_align|default('center') %}

{# Normalize classes - handle both array and string formats #}
{% set additional_classes = classes|default('') %}
{% if additional_classes is iterable %}
  {% set additional_classes = additional_classes|join(' ') %}
{% endif %}

{% set hero_bg_color = background_color|default('primary') %}

{% set hero_variants =
  html_cva(
    base: ['relative flex items-center justify-center overflow-hidden'],
    variants: {
      variant: {
        big: ['min-h-[75vh] min-h-[500px] py-20 md:py-24 xl:py-32'],
        small: ['min-h-[315px] py-14 md:py-16 xl:py-20']
      },
      backgroundColor: {
        primary: 'hero-gradient-primary',
        secondary: 'hero-gradient-secondary',
        accent: 'hero-gradient-accent',
        muted: 'hero-gradient-muted',
        foreground: 'hero-gradient-foreground',
        'secondary-foreground': 'hero-gradient-secondary-foreground'
      }
    }
  )
%}

{% set content_inner_variants =
  html_cva(
    base: ['flex flex-col w-full lg:max-w-[70%]'],
    variants: {
      textColor: {
        light: 'text-white',
        dark: 'text-foreground'
      },
      variant: {
        big: 'gap-6 md:gap-8',
        small: 'gap-4 md:gap-5'
      },
      align: {
        left: 'items-start text-left',
        center: 'items-center text-center mx-auto',
        right: 'items-end text-right ml-auto'
      }
    }
  )
%}

{% set cta_variants =
  html_cva(
    base: ['flex flex-wrap gap-3 mt-2 md:mt-4'],
    variants: {
      align: {
        left: 'justify-start',
        center: 'justify-center',
        right: 'justify-end'
      }
    }
  )
%}

{% set heading_size = hero_variant == 'big' ? 'heading-responsive-6xl' : 'heading-responsive-4xl' %}
{% set has_cta_1 = cta_label is not empty and cta_href is not empty %}
{% set has_cta_2 = cta_2_label is not empty and cta_2_href is not empty %}

<section
  class="{{
  hero_variants.apply(
    { variant: hero_variant, backgroundColor: hero_bg_color },
    additional_classes
  )
  }}"
>

  {# ── Decorazioni geometriche ────────────────────────────────────── #}
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full border border-foreground/10"></div>
    <div class="absolute -bottom-20 -right-20 w-64 h-64 rounded-full border border-foreground/8"></div>
    <div class="absolute -top-16 -left-16 w-48 h-48 rounded-full border border-foreground/10"></div>
    <div class="absolute top-1/2 left-0 right-0 h-px bg-gradient-to-r from-transparent via-foreground/10 to-transparent"></div>
  </div>

  {# ── Content ────────────────────────────────────────────────────── #}
  <div class="relative z-10 container mx-auto px-4">
  <div
    class="{{
    content_inner_variants.apply({
      textColor: hero_text_color,
      variant: hero_variant,
      align: hero_align
    })
    }}"
  >
    {# Heading #}
    {% if heading_text is not empty %}
      {{
        include(
          'mercury:heading',
          {
            heading_text: heading_text,
            level: hero_heading_level,
            url: '',
            text_color: hero_text_color == 'light' ? 'inverted' : 'default',
            text_size: heading_size,
            align: hero_align
          },
          with_context: false
        )
      }}
    {% endif %}

    {# Description #}
    {% if description is not empty %}
      <p class="{{ hero_variant == 'big' ? 'text-lg md:text-xl xl:text-2xl max-w-2xl' : 'text-base md:text-lg xl:text-xl max-w-xl' }} opacity-90">
        {{ description }}
      </p>
    {% endif %}

    {# CTAs #}
    {% if has_cta_1 or has_cta_2 %}
      <div class="{{ cta_variants.apply({ align: hero_align }) }}">
        {% if has_cta_1 %}
          {{
            include(
              '@mercury/components/button/button.twig',
              {
                variant: cta_variant|default('primary-inverted'),
                size: hero_variant == 'big' ? 'large' : 'medium',
                label: cta_label,
                href: cta_href,
                icon: cta_icon|default(''),
                mobile_width: false
              },
              with_context: false
            )
          }}
        {% endif %}
        {% if has_cta_2 %}
          {{
            include(
              '@mercury/components/button/button.twig',
              {
                variant: cta_2_variant|default('secondary-inverted'),
                size: hero_variant == 'big' ? 'large' : 'medium',
                label: cta_2_label,
                href: cta_2_href,
                icon: cta_2_icon|default(''),
                mobile_width: false
              },
              with_context: false
            )
          }}
        {% endif %}
      </div>
    {% endif %}
  </div>
  </div>

</section>
