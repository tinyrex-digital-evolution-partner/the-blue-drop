  {# ── Corpo principale ────────────────────────────────────────────── #}
  <div class="container mx-auto px-4 py-14 md:py-16">
    <div class="flex flex-col gap-10 lg:flex-row lg:justify-between lg:gap-24">
      {# Colonna brand — sinistra #}
      <div class="flex w-full max-w-md flex-col gap-5 lg:w-120">
        <div class="flex items-center gap-3">
          <img src="/themes/custom/mercury/logo-w.svg" alt="The Blue Drop" class="h-8" />
        </div>
        <p class="text-sm leading-relaxed text-background/55">
          The Blue Drop è il blog di riferimento per la community italiana che lavora con Drupal. Qui condividiamo tutorial, guide alla configurazione
          e news aggiornate su core e moduli, per aiutare chi lavora ogni giorno con questo CMS.
        </p>
        <p class="text-xs leading-relaxed text-background/40">
          Drupal è un marchio registrato di Dries Buytaert. Questo sito non è affiliato alla Drupal Association o al Drupal Project.
        </p>
      </div>

      {# Menu — destra #}
      <div class="grid grid-cols-2 gap-12 md:gap-20">
        {# Colonna Community #}
        <div class="flex w-full flex-col gap-5 lg:w-60">
          <h3 class="text-sm font-bold tracking-widest text-background/50 uppercase">Community</h3>
          <ul class="flex flex-col gap-3">
            {% for item in [
              {
                label: 'Forum',
                href: '#'
              },
              {
                label: 'Slack',
                href: '#'
              },
              {
                label: 'Meetup',
                href: '#'
              },
              {
                label: 'DrupalCamp',
                href: '#'
              },
              {
                label: 'Contribuisci',
                href: '#'
              }
            ] %}
              <li>
                <a href="{{ item.href }}" class="text-sm text-background/60 transition-colors duration-200 hover:text-background">{{ item.label }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>

        {# Colonna Risorse #}
        <div class="flex w-full flex-col gap-5 lg:w-60">
          <h3 class="text-sm font-bold tracking-widest text-background/50 uppercase">Risorse</h3>
          <ul class="flex flex-col gap-3">
            {% for item in [
              {
                label: 'Blog',
                href: '/blog'
              },
              {
                label: 'Tutorial',
                href: '/tutorial'
              },
              {
                label: 'Documentazione',
                href: '#'
              },
              {
                label: 'Progetti',
                href: '#'
              },
              {
                label: 'Moduli consigliati',
                href: '#'
              }
            ] %}
              <li>
                <a href="{{ item.href }}" class="text-sm text-background/60 transition-colors duration-200 hover:text-background">{{ item.label }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>

    {# Slot per contenuto dinamico aggiuntivo (footer_first / footer_last) #}
    {% block footer_first %}

    {% endblock %}
    {% block footer_last %}

    {% endblock %}
  </div>

  {# ── Bottom bar ──────────────────────────────────────────────────── #}
  <div class="border-t border-background/10">
    <div class="container mx-auto flex flex-col items-center justify-between gap-3 px-4 py-5 sm:flex-row">
      <p class="text-xs text-background/40">
        © {{ 'now'|date('Y') }} The Blue Drop. Contenuti rilasciati sotto licenza
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="underline transition-colors duration-200 hover:text-background">
          CC BY-SA 4.0
        </a>.
      </p>
      <p class="text-xs text-background/40">
        Blog indipendente a cura di
        <a
          href="https://www.alexpezzini.it"
          title="Alex Pezzini - Consulenza Drupal"
          class="underline transition-colors duration-200 hover:text-background"
        >
          Alex Pezzini
        </a>.
      </p>
    </div>
  </div>
</footer>
